// Define como os dados são salvos
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Modelo de Usuário [cite: 25]
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // A senha será criptografada
  createdAt DateTime @default(now())
  
  // Relacionamentos (um usuário tem muitas mensagens e chats)
  sentMessages     Message[]
  chatsAsInitiator Chat[]    @relation("Initiator")
  chatsAsReceiver  Chat[]    @relation("Receiver")
}

// Modelo de Chat [cite: 26]
model Chat {
  id          Int       @id @default(autoincrement())
  status      String    @default("PENDING") // PENDING, ACTIVE, CLOSED
  createdAt   DateTime  @default(now())
  report      String?   // Campo opcional para o relatório de IA [cite: 31]
  
  // Quem começou a 'ligação' e quem recebeu
  initiatorId Int
  initiator   User      @relation("Initiator", fields: [initiatorId], references: [id])
  receiverId  Int
  receiver    User      @relation("Receiver", fields: [receiverId], references: [id])

  messages    Message[]
}

// Modelo de Mensagem [cite: 27]
model Message {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  
  chatId    Int
  chat      Chat     @relation(fields: [chatId], references: [id])
  
  senderId  Int
  sender    User     @relation(fields: [senderId], references: [id])
}
